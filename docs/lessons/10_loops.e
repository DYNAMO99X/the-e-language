say "Counting to 10:"
let n be 1
repeat 10 times
    say n
    let n be n plus 1
end

say ""

say "Countdown:"
let c be 10
repeat 10 times
    say c
    let c be c minus 1
end

say ""

say "Multiplication table for 5:"
let i be 1
repeat 12 times
    let answer be i times 5
    say "5 times " , i , " = " , answer
    let i be i plus 1
end
